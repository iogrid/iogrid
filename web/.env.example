# iogrid — web/ environment variables (sample)
#
# Copy to `.env.local` for local development. The same variables are
# baked into the standalone build at CI time via the workflow env: block.

# NextAuth — required at runtime (not at build time).
AUTH_SECRET=change-me-at-runtime
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# Gateway-bff base URL (server + client side). `browserApi()` /
# `serverApi()` both default to this.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8090

# Solana wallet adapter / token configuration.
#
# Defaults are safe pre-TGE: the public mainnet-beta RPC works for
# read-only balance fetches in dev (rate-limited; use Helius for prod);
# the GRID mint defaults to a deterministic placeholder so the build
# compiles before the token is deployed.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_GRID_MINT_ADDRESS=
