{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-large"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-large",
        "simulator": false
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": "buildNumber",
      "ios": {
        "resourceClass": "m-large"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "founder@iogrid.org",
        "ascAppId": "TBD-set-after-first-tf-upload",
        "appleTeamId": "TBD-set-via-eas-credentials"
      }
    }
  }
}
