<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- packet-tunnel-provider: the entitlement type for full L3 VPN
	     tunneling via wireguard/openvpn/IPsec userspace impls.
	     Granted on the Dynolabs Apple Developer team. -->
	<key>com.apple.developer.networking.networkextension</key>
	<array>
		<string>packet-tunnel-provider</string>
	</array>
	<!--
	    App Group + Keychain access group dropped for v1.
	    Apple's REST API doesn't expose POST /v1/appGroups, and
	    Spaceship::Portal needs Apple-ID-password auth (blocked by
	    2FA). Re-add when the founder click-creates the App Group
	    OR when #576 WireGuardKit lands and we need shared Keychain
	    for the customer's WG private key.

	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.io.iogrid.app</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)group.io.iogrid.app</string>
	</array>
	-->
</dict>
</plist>
