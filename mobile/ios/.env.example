# iogrid mobile (Expo) — environment variables (sample)
#
# Copy to `.env` (or `.env.local`) for local development. All
# `EXPO_PUBLIC_*` vars are inlined into the JS bundle at build time, so
# these are NON-SECRET, client-visible values only.

# --- Coordinator ---
# Defaults to app.json `extra.coordinatorURL` when unset.
# EXPO_PUBLIC_COORDINATOR_URL=https://api.iogrid.org

# --- Solana / $GRID ($GRID balance card + Ping SPL-Approve pay flow) ---
#
# Read-only Solana RPC. Defaults to devnet in code
# (grid_balance.ts / ping-pay.ts) when unset.
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
#
# $GRID token mint address. The MAINNET mint is PRE-LAUNCH and is a
# founder-gated decision — do NOT hard-code a mainnet placeholder here
# (a wrong mint routes real funds to a dead ATA — see docs/TOKENOMICS.md).
#
# DEVNET default below is a real Token-2022 (9-decimal) test mint with a
# non-zero treasury balance, so the balance card + Ping SPL-Approve flow
# are testable end-to-end against devnet. Refs #629.
EXPO_PUBLIC_GRID_TOKEN_MINT=BaQvWwb1wUGvWJXPEUbLEwPeeYMd4sKvp2S7obzTWorR
#
# Delegate vault pubkey for the Ping SPL-Approve (delegate) pay flow.
# Defaults to ping-pay.ts `vpnVault` when unset.
# EXPO_PUBLIC_IOGRID_VPN_VAULT=
