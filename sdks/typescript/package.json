{
  "name": "@iogrid/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the iogrid customer API.",
  "license": "Apache-2.0",
  "homepage": "https://iogrid.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iogrid/iogrid.git",
    "directory": "sdks/typescript"
  },
  "bugs": {
    "url": "https://github.com/iogrid/iogrid/issues"
  },
  "author": "iogrid <support@iogrid.org>",
  "keywords": ["iogrid", "sdk", "proxy", "workload", "grid", "bandwidth"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
