{
  "uid": "iogrid-overview",
  "title": "iogrid — Overview",
  "tags": ["iogrid", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "cluster_id",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "mimir"},
        "query": "label_values(up{namespace=\"iogrid\"}, cluster_id)",
        "current": {"text": "iogrid-prod", "value": "iogrid-prod"},
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services healthy",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{
        "expr": "sum(up{namespace=\"iogrid\",cluster_id=\"$cluster_id\"}) / count(up{namespace=\"iogrid\",cluster_id=\"$cluster_id\"})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Proxy req/s",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{
        "expr": "sum(rate(http_server_requests_total{service=\"proxy-gateway\",cluster_id=\"$cluster_id\"}[5m]))",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx rate",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{
        "expr": "sum(rate(http_server_requests_total{service=\"proxy-gateway\",code=~\"5..\",cluster_id=\"$cluster_id\"}[5m])) / sum(rate(http_server_requests_total{service=\"proxy-gateway\",cluster_id=\"$cluster_id\"}[5m]))",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.005},
              {"color": "red", "value": 0.01}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Connected providers",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [{
        "expr": "sum(providers_connected{cluster_id=\"$cluster_id\"})",
        "refId": "A"
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate by service",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{
        "expr": "sum by (service) (rate(http_server_requests_total{namespace=\"iogrid\",cluster_id=\"$cluster_id\"}[5m]))",
        "legendFormat": "{{service}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "p95 latency by service",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_server_request_duration_seconds_bucket{namespace=\"iogrid\",cluster_id=\"$cluster_id\"}[5m])))",
        "legendFormat": "{{service}}",
        "refId": "A"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
