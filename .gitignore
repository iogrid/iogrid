# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
bin/
dist/

# Top-level pnpm workspace artefacts (web/ + marketing/ + docs-site/)
/node_modules/
.pnpm-store/

# IDE
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Generated proto files — we DO commit Buf-generated stubs so consumers
# of the repo can `go build` without running buf locally. CI regenerates
# on every PR touching proto/ and fails if the diff is non-empty.
# (Intentionally NOT ignored: coordinator/internal/pb/**, web/src/lib/pb/**)

# Secrets / local config
.env
.env.local
*.local.yaml
secrets/

# Tart / VM images (large, don't commit)
*.qcow2
*.vmdk
tart-images/

# Logs
*.log
logs/

# Coverage
coverage.txt
coverage.html

# Anchor / Solana build artifacts
contracts/.anchor/
contracts/target/
contracts/node_modules/
contracts/yarn.lock
contracts/package-lock.json
contracts/test-ledger/

# Wallet keypairs — never commit
contracts/*.json
!contracts/package.json
!contracts/tsconfig.json

# Rust
daemon/target/
target/
**/*.rs.bk
Cargo.lock.bak

# Marketing (Next.js) — safety net on top of marketing/.gitignore
marketing/node_modules/
marketing/.next/
marketing/out/
marketing/coverage/
marketing/.lighthouseci/
marketing/.vercel/
marketing/.turbo/
marketing/*.tsbuildinfo

# Docs site (Astro / Starlight)
docs-site/node_modules/
docs-site/dist/
docs-site/.astro/
docs-site/.lighthouseci/
docs-site/public/og-default.png
docs-site/public/openapi.yaml
docs-site/*.tsbuildinfo

# Customer SDKs — build outputs only; sources are committed.
sdks/typescript/node_modules/
sdks/typescript/dist/
sdks/typescript/coverage/
sdks/typescript/*.tgz
sdks/python/.venv/
sdks/python/.hatch/
sdks/python/.pytest_cache/
sdks/python/.mypy_cache/
sdks/python/.ruff_cache/
sdks/python/dist/
sdks/python/build/
sdks/python/*.egg-info/
sdks/python/**/__pycache__/
sdks/go/vendor/
sdks/java/.gradle/
sdks/java/build/
sdks/java/out/

# pnpm hoists workspace deps to the repo root.
/node_modules/

