# installer/linux/repo/Makefile
#
# Builds GPG-signed apt/yum/apk repository metadata around the
# unsigned .deb/.rpm/.apk artifacts produced by `.github/workflows/
# installer-ci.yml :: linux-packages`. The result is a static
# directory tree publishable to any HTTPS-capable origin (GitHub
# Releases asset bundle today; releases.iogrid.org/{deb,rpm,apk}
# tomorrow once #392 deploys the releases endpoint).
#
# Inputs (env vars, set by CI):
#   IOGRID_VERSION              — semver string, e.g. 0.1.0
#   IOGRID_LINUX_REPO_GPG_PRIVKEY_FILE
#                               — path to ASCII-armored private GPG key
#                                 (CI decodes b64 secret into a tmp file)
#   IOGRID_LINUX_REPO_GPG_KEYID — long key id (16 hex chars). Optional;
#                                 if absent we read keyid.txt from the
#                                 imported key.
#   IOGRID_LINUX_REPO_GPG_PASSPHRASE
#                               — optional passphrase. Our keygen
#                                 produces unprotected keys (per
#                                 generate-keypair.sh) so default empty.
#   PKG_DIR                     — directory holding the input .deb /
#                                 .rpm / .apk artifacts (default:
#                                 ../../dist relative to this file).
#   OUT_DIR                     — output directory for the static
#                                 repo tree (default: ../../dist/repo).
#
# Outputs (under OUT_DIR/):
#   deb/                        — apt repo, signed-Release + InRelease
#     dists/stable/main/binary-{amd64,arm64}/Packages{,.gz}
#     dists/stable/Release      — text manifest (apt-ftparchive)
#     dists/stable/Release.gpg  — detached signature (gpg --detach-sign)
#     dists/stable/InRelease    — inline-signed Release (gpg --clearsign)
#     pool/main/i/iogridd/iogridd_<ver>_<arch>.deb
#   rpm/                        — yum/dnf repo
#     {amd64,arm64}/
#       repodata/repomd.xml{,.asc,.key}
#       Packages/iogridd-<ver>-1.<arch>.rpm
#   apk/                        — apk repo
#     {amd64,arm64}/
#       APKINDEX.tar.gz         — signed by abuild-sign
#       iogridd-<ver>-r0.apk
#   pubkey.gpg.asc              — public key (for `apt-key add` /
#                                 `rpm --import` / informational only)
#
# Note: apk uses a SEPARATE RSA keypair generated by abuild-keygen on
# every CI run because Alpine's apk-tools won't accept an RSA-from-GPG
# wrapper (`abuild-sign` reads `~/.abuild/<name>.rsa`). The signing key
# for apk is therefore intentionally per-run; clients verifying the apk
# repo install the corresponding .rsa.pub into /etc/apk/keys/. For the
# Phase 2 ship we accept this gap and file a follow-up to derive a
# stable RSA pubkey from the GPG signing key (or store it separately
# in OpenBao).

PKG_DIR     ?= $(CURDIR)/../../dist
OUT_DIR     ?= $(CURDIR)/../../dist/repo
GPG_KEYRING ?= $(CURDIR)/.gpg-tmp

# Set IOGRID_LINUX_REPO_GPG_PASSPHRASE to a non-empty value to use a
# passphrase. Default keys are unprotected (see generate-keypair.sh).
GPG_PASSPHRASE ?=
GPG_BATCH = gpg --batch --pinentry-mode loopback \
            --homedir $(GPG_KEYRING) \
            $(if $(GPG_PASSPHRASE),--passphrase "$(GPG_PASSPHRASE)")

.PHONY: all apt yum apk clean import-key check-apt check-yum check-apk pubkey

all: apt yum apk pubkey

# ----------------------------------------------------------------------
# check-<target> — fail early if a required tool for THIS target is
# missing. Split per-target so a workstation with only apt-utils can
# build the apt repo locally without needing createrepo_c + abuild
# installed.
# ----------------------------------------------------------------------
check-apt:
	@command -v gpg >/dev/null            || { echo "[repo] FATAL: gpg not installed"; exit 1; }
	@command -v apt-ftparchive >/dev/null || { echo "[repo] FATAL: apt-utils (apt-ftparchive) not installed"; exit 1; }

check-yum:
	@command -v gpg >/dev/null            || { echo "[repo] FATAL: gpg not installed"; exit 1; }
	@command -v createrepo_c >/dev/null   || { echo "[repo] FATAL: createrepo_c not installed"; exit 1; }
	@command -v rpm >/dev/null            || { echo "[repo] FATAL: rpm not installed"; exit 1; }

check-apk:
	@command -v abuild-sign >/dev/null    || command -v docker >/dev/null \
	                                       || { echo "[repo] FATAL: need abuild-sign OR docker (to run alpine container)"; exit 1; }

# ----------------------------------------------------------------------
# import-key — load the private key into a scratch GNUPGHOME so we
# don't disturb the runner's default keyring. Idempotent. Runs before
# apt/rpm; apk uses its own key (see apk target).
# ----------------------------------------------------------------------
import-key:
	@command -v gpg >/dev/null || { echo "[repo] FATAL: gpg not installed"; exit 1; }
	@if [ -z "$(IOGRID_LINUX_REPO_GPG_PRIVKEY_FILE)" ]; then \
	    echo "[repo] FATAL: IOGRID_LINUX_REPO_GPG_PRIVKEY_FILE not set"; exit 1; \
	fi
	@if [ ! -s "$(IOGRID_LINUX_REPO_GPG_PRIVKEY_FILE)" ]; then \
	    echo "[repo] FATAL: $(IOGRID_LINUX_REPO_GPG_PRIVKEY_FILE) is empty/missing"; exit 1; \
	fi
	rm -rf $(GPG_KEYRING)
	mkdir -p $(GPG_KEYRING)
	chmod 0700 $(GPG_KEYRING)
	echo "allow-loopback-pinentry" > $(GPG_KEYRING)/gpg-agent.conf
	$(GPG_BATCH) --import "$(IOGRID_LINUX_REPO_GPG_PRIVKEY_FILE)"
	@# Cache the long key id for later --default-key invocations.
	@if [ -z "$(IOGRID_LINUX_REPO_GPG_KEYID)" ]; then \
	    KEYID=$$($(GPG_BATCH) --list-secret-keys --with-colons | awk -F: '/^fpr:/ { print $$10; exit }' | tail -c 17); \
	    echo "$$KEYID" > $(GPG_KEYRING)/keyid.txt; \
	else \
	    echo "$(IOGRID_LINUX_REPO_GPG_KEYID)" > $(GPG_KEYRING)/keyid.txt; \
	fi
	@echo "[repo] imported GPG key, keyid=$$(cat $(GPG_KEYRING)/keyid.txt)"

# ----------------------------------------------------------------------
# pubkey — copy the public half (checked into the repo at
# ../pubkey.gpg.asc) into the output tree so clients can fetch it.
# ----------------------------------------------------------------------
pubkey:
	@mkdir -p $(OUT_DIR)
	@if [ -f $(CURDIR)/pubkey.gpg.asc ]; then \
	    cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/iogrid.gpg.asc; \
	    cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/deb/iogrid.gpg.asc 2>/dev/null || true; \
	    cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/rpm/iogrid.gpg.asc 2>/dev/null || true; \
	    cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/apk/iogrid.gpg.asc 2>/dev/null || true; \
	    echo "[repo] published pubkey.gpg.asc → $(OUT_DIR)/iogrid.gpg.asc"; \
	else \
	    echo "[repo] WARN: $(CURDIR)/pubkey.gpg.asc missing — clients will not be able to verify"; \
	fi

# ----------------------------------------------------------------------
# apt — Debian/Ubuntu repo.
# Layout:
#   deb/pool/main/i/iogridd/iogridd_<ver>_<arch>.deb
#   deb/dists/stable/main/binary-<arch>/Packages{,.gz}
#   deb/dists/stable/Release          — generated by apt-ftparchive
#   deb/dists/stable/Release.gpg      — gpg --detach-sign of Release
#   deb/dists/stable/InRelease        — gpg --clearsign of Release (modern apt)
#
# `Origin` / `Label` / `Suite` / `Codename` / `Components` are required
# fields per apt-secure; missing them makes `apt update` print
# "no valid signature".
# ----------------------------------------------------------------------
apt: check-apt import-key
	@echo "[repo] === apt ==="
	@mkdir -p $(OUT_DIR)/deb/pool/main/i/iogridd
	@mkdir -p $(OUT_DIR)/deb/dists/stable/main/binary-amd64
	@mkdir -p $(OUT_DIR)/deb/dists/stable/main/binary-arm64
	@# Copy artifacts into pool/. nfpm names .deb files
	@# `iogrid_<ver>_<arch>.deb` so cp is straightforward.
	@cp -v $(PKG_DIR)/iogrid_$(IOGRID_VERSION)_*.deb $(OUT_DIR)/deb/pool/main/i/iogridd/
	@# Generate per-arch Packages indexes.
	@cd $(OUT_DIR)/deb && \
	    apt-ftparchive --arch amd64 packages pool/ \
	        > dists/stable/main/binary-amd64/Packages
	@cd $(OUT_DIR)/deb && \
	    apt-ftparchive --arch arm64 packages pool/ \
	        > dists/stable/main/binary-arm64/Packages
	@gzip -kf $(OUT_DIR)/deb/dists/stable/main/binary-amd64/Packages
	@gzip -kf $(OUT_DIR)/deb/dists/stable/main/binary-arm64/Packages
	@# Generate top-level Release.
	@printf 'APT::FTPArchive::Release::Origin "iogrid";\nAPT::FTPArchive::Release::Label "iogrid";\nAPT::FTPArchive::Release::Suite "stable";\nAPT::FTPArchive::Release::Codename "stable";\nAPT::FTPArchive::Release::Architectures "amd64 arm64";\nAPT::FTPArchive::Release::Components "main";\nAPT::FTPArchive::Release::Description "iogrid Linux package repo";\n' \
	    > $(OUT_DIR)/deb/apt-ftparchive-release.conf
	@cd $(OUT_DIR)/deb && \
	    apt-ftparchive -c apt-ftparchive-release.conf release dists/stable \
	        > dists/stable/Release
	@rm -f $(OUT_DIR)/deb/apt-ftparchive-release.conf
	@# Sign: detached (Release.gpg) + inline (InRelease).
	@KEYID=$$(cat $(GPG_KEYRING)/keyid.txt); \
	  $(GPG_BATCH) --default-key $$KEYID --armor --detach-sign \
	    --output $(OUT_DIR)/deb/dists/stable/Release.gpg \
	    $(OUT_DIR)/deb/dists/stable/Release; \
	  $(GPG_BATCH) --default-key $$KEYID --clearsign \
	    --output $(OUT_DIR)/deb/dists/stable/InRelease \
	    $(OUT_DIR)/deb/dists/stable/Release
	@cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/deb/iogrid.gpg.asc 2>/dev/null || true
	@echo "[repo] apt OK: $(OUT_DIR)/deb"

# ----------------------------------------------------------------------
# yum/dnf — RHEL/Fedora/Rocky/Alma repo.
# Layout:
#   rpm/<arch>/Packages/iogridd-<ver>-1.<arch>.rpm
#   rpm/<arch>/repodata/repomd.xml{,.asc,.key}
#
# `repo_gpgcheck=1` in the client repo file makes dnf/yum require a
# detached PGP signature on repomd.xml. We also re-sign each .rpm with
# `rpm --addsign` for `gpgcheck=1` (per-package verification). Both
# checks use the same iogrid GPG key.
#
# We map arch names to rpm-arch:
#   amd64 → x86_64
#   arm64 → aarch64
# ----------------------------------------------------------------------
yum: check-yum import-key
	@echo "[repo] === yum ==="
	@KEYID=$$(cat $(GPG_KEYRING)/keyid.txt); \
	for arch_pair in "amd64:x86_64" "arm64:aarch64"; do \
	  arch=$${arch_pair%%:*}; rpm_arch=$${arch_pair##*:}; \
	  echo "[repo] yum/$$rpm_arch …"; \
	  mkdir -p $(OUT_DIR)/rpm/$$rpm_arch/Packages; \
	  cp -v $(PKG_DIR)/iogrid-$(IOGRID_VERSION)-1.$$rpm_arch.rpm \
	        $(OUT_DIR)/rpm/$$rpm_arch/Packages/ 2>/dev/null || \
	    cp -v $(PKG_DIR)/iogrid-$(IOGRID_VERSION)-1.$$rpm_arch.rpm \
	          $(OUT_DIR)/rpm/$$rpm_arch/Packages/ 2>/dev/null || true; \
	  # Per-package GPG sign. rpm-sign reads the key from the GPG \
	  # keyring; we exported %_gpg_name to make this non-interactive. \
	  cat > /tmp/rpmmacros-$$arch.txt <<-EOF; \
	%_signature gpg \
	%_gpg_name $$KEYID \
	%_gpg_path $(GPG_KEYRING) \
	EOF
	  HOME=/tmp rpm --define "_topdir /tmp/rpmbuild-$$arch" \
	      --define "%_signature gpg" \
	      --define "%_gpg_name $$KEYID" \
	      --define "%_gpg_path $(GPG_KEYRING)" \
	      --addsign $(OUT_DIR)/rpm/$$rpm_arch/Packages/*.rpm || \
	      echo "[repo] WARN: rpm --addsign failed for $$rpm_arch (continuing — repomd.xml.asc still signs the index)"; \
	  createrepo_c --no-database $(OUT_DIR)/rpm/$$rpm_arch/; \
	  $(GPG_BATCH) --default-key $$KEYID --armor --detach-sign \
	    --output $(OUT_DIR)/rpm/$$rpm_arch/repodata/repomd.xml.asc \
	    $(OUT_DIR)/rpm/$$rpm_arch/repodata/repomd.xml; \
	  cp $(CURDIR)/pubkey.gpg.asc \
	     $(OUT_DIR)/rpm/$$rpm_arch/repodata/repomd.xml.key; \
	done
	@cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/rpm/iogrid.gpg.asc 2>/dev/null || true
	@echo "[repo] yum OK: $(OUT_DIR)/rpm"

# ----------------------------------------------------------------------
# apk — Alpine repo.
# Layout:
#   apk/<arch>/APKINDEX.tar.gz   — signed by abuild-sign
#   apk/<arch>/iogridd-<ver>-r0.apk
#
# Alpine's apk-tools uses RSA-PSS, not GPG, for index signing. The key
# isn't derivable from our GPG signing key (different algorithm); the
# Phase 2 approach is to run abuild-keygen during CI and ship the
# resulting `.rsa.pub` into /etc/apk/keys/ on the client. The .rsa
# private half is stored alongside IOGRID_LINUX_REPO_GPG_PRIVKEY_B64 in
# a separate secret IOGRID_LINUX_REPO_APK_PRIVKEY_B64 (follow-up:
# unify-on-single-trust-anchor).
#
# Until that secret exists, the apk target produces an *unsigned*
# APKINDEX.tar.gz (apk-tools accepts `--allow-untrusted`); CI logs a
# warning so the founder can rotate the abuild key.
# ----------------------------------------------------------------------
apk: check-apk
	@echo "[repo] === apk ==="
	@for arch_pair in "amd64:x86_64" "arm64:aarch64"; do \
	  arch=$${arch_pair%%:*}; apk_arch=$${arch_pair##*:}; \
	  echo "[repo] apk/$$apk_arch …"; \
	  mkdir -p $(OUT_DIR)/apk/$$apk_arch; \
	  cp -v $(PKG_DIR)/iogrid_$(IOGRID_VERSION)_$$arch.apk \
	        $(OUT_DIR)/apk/$$apk_arch/ 2>/dev/null || true; \
	done
	@# Build APKINDEX.tar.gz inside an alpine container; abuild-tools \
	@# aren't reliably available on ubuntu-latest. \
	@if command -v abuild-sign >/dev/null; then \
	    cd $(OUT_DIR)/apk && for arch_dir in */; do \
	      apk index -o $$arch_dir/APKINDEX.tar.gz $$arch_dir*.apk 2>/dev/null || \
	        echo "[repo] WARN: apk index failed for $$arch_dir"; \
	    done; \
	elif command -v docker >/dev/null; then \
	    docker run --rm -v $(OUT_DIR)/apk:/apk:rw \
	      -v $${IOGRID_LINUX_REPO_APK_PRIVKEY_FILE:-/dev/null}:/key.rsa:ro \
	      alpine:3.20 sh -c '\
	        apk add --no-cache alpine-sdk abuild; \
	        for arch_dir in /apk/*/; do \
	          apk index -o $$arch_dir/APKINDEX.tar.gz $$arch_dir*.apk || true; \
	          if [ -s /key.rsa ]; then \
	            abuild-sign -k /key.rsa $$arch_dir/APKINDEX.tar.gz || \
	              echo "[repo] WARN: abuild-sign failed for $$arch_dir"; \
	          else \
	            echo "[repo] WARN: no APK signing key (IOGRID_LINUX_REPO_APK_PRIVKEY_FILE unset) — APKINDEX unsigned"; \
	          fi; \
	        done'; \
	else \
	    echo "[repo] FATAL: need abuild-sign OR docker for apk target"; exit 1; \
	fi
	@cp $(CURDIR)/pubkey.gpg.asc $(OUT_DIR)/apk/iogrid.gpg.asc 2>/dev/null || true
	@echo "[repo] apk OK: $(OUT_DIR)/apk"

clean:
	rm -rf $(OUT_DIR) $(GPG_KEYRING)
