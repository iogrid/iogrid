<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>iogrid</title>
    <organization>org.iogrid</organization>
    <domains enable_currentUserHome="true" enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
    <welcome    file="Welcome.html"    mime-type="text/html"/>
    <license    file="License.html"    mime-type="text/html"/>
    <conclusion file="Conclusion.html" mime-type="text/html"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="13.0"/>
        </allowed-os-versions>
    </volume-check>
    <pkg-ref id="org.iogrid.daemon"
             auth="root"
             version="0.1.0">iogrid-component-0.1.0.pkg</pkg-ref>
    <choices-outline>
        <line choice="default">
            <line choice="org.iogrid.daemon"/>
        </line>
    </choices-outline>
    <choice id="default" title="iogrid daemon"/>
    <choice id="org.iogrid.daemon"
            visible="false"
            title="iogrid daemon"
            description="The iogrid provider daemon, its LaunchAgent, and the macOS menu-bar status app that drives Check-for-Updates via Sparkle (issue #388).">
        <pkg-ref id="org.iogrid.daemon"/>
    </choice>
</installer-gui-script>
