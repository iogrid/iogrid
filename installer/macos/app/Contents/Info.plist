<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        iogridd.app — minimal bundle wrapper around the Rust `iogridd` binary.

        The bundle exists for ONE reason today: to host the Sparkle.framework so
        the daemon can self-update via the standard macOS appcast.xml flow. The
        executable inside is the same single static Rust binary that's also
        installed at /usr/local/iogrid/iogridd. The LaunchAgent (LaunchAgents/
        org.iogrid.daemon.plist) keeps targeting /usr/local/iogrid/iogridd for
        backwards compatibility — the .app is the update-host, not the run host.

        Phase 1 of EPIC #348 lands the bundle skeleton + Sparkle wiring. The
        Sparkle framework binary is fetched from the official 2.x release in CI
        (see installer/macos/sparkle/fetch-sparkle.sh) and dropped into
        Contents/Frameworks/Sparkle.framework before pkgbuild runs.
    -->
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>iogrid</string>
    <key>CFBundleExecutable</key>
    <string>iogridd</string>
    <key>CFBundleIdentifier</key>
    <string>org.iogrid.daemon</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>iogrid</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>0.1.0</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright (c) iogrid contributors. MIT licensed.</string>

    <!--
        Sparkle 2.x configuration. See https://sparkle-project.org/documentation/
        for the full key reference.

        SUFeedURL          — RSS appcast URL the framework polls. Generated by
                             daemon-ci.yml on every tag push (see
                             .github/workflows/daemon-ci.yml::generate-appcast).
        SUEnableAutomaticChecks
                           — opt providers in to silent background checks; they
                             can flip this in System Settings if they prefer.
        SUEnableInstallerLauncherService
                           — required for Sparkle 2's XPC-based installer that
                             can apply updates without a re-prompt for admin
                             rights on every cycle.
        SUPublicEDKey      — EdDSA (ed25519) trust anchor. The matching private
                             key lives in the K8s Secret `iogrid-sparkle-signing`
                             (template at infra/k8s/base/sparkle/secret.yaml).
                             A signature mismatch makes Sparkle reject the
                             update, so this key MUST be checked into the repo
                             — it's not a secret, it's the verification root.
        SUScheduledCheckInterval
                           — 86400s == 24h, matches the existing manifest.json
                             polling cadence in installer/auto-update/README.md.
    -->
    <key>SUFeedURL</key>
    <string>https://releases.iogrid.org/macos/appcast.xml</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUEnableInstallerLauncherService</key>
    <true/>
    <!--
        SUPublicEDKey is substituted at build time by installer/macos/Makefile
        from sparkle/pubkey.ed25519 (or the SU_PUBLIC_ED_KEY make-var). The
        value committed here is a placeholder that satisfies xmllint + the
        Sparkle plist parser shape — see installer/macos/sparkle/README.md
        for the rotation story.
    -->
    <key>SUPublicEDKey</key>
    <string>__SU_PUBLIC_ED_KEY__</string>
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
    <key>SUAllowsAutomaticUpdates</key>
    <true/>
</dict>
</plist>
